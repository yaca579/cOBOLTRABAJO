<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #12151B;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.DetallePartidoController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #0E1116; -fx-padding: 0 30; -fx-border-color: #2D323E; -fx-border-width: 0 0 1 0;">
        <Button onAction="#navInici" styleClass="sidebar-button" text="← INICI" style="-fx-text-fill: #E5C04A; -fx-font-weight: bold;" />
        <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="MÉS APOSTES" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblSaldo" style="-fx-text-fill: #E5C04A; -fx-font-size: 18px; -fx-font-weight: bold;" text="Saldo: 0.00 €" />
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox alignment="TOP_CENTER" spacing="40.0" style="-fx-padding: 40;">

            <Label fx:id="lblTituloPartido" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="⚽ PARTIT" />

            <VBox fx:id="contenedorMercados" maxWidth="800.0" spacing="30.0">
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>