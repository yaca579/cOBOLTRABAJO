<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #05070A;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.SlotsController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #0E1116; -fx-padding: 0 30; -fx-border-color: #00D4FF; -fx-border-width: 0 0 2 0;">
        <Button onAction="#volverAlCasino" styleClass="sidebar-button" text="← VOLVER AL CASINO" style="-fx-text-fill: #E5C04A; -fx-font-weight: bold; -fx-font-size: 16px;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #00D4FF; -fx-font-size: 26px; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, #00D4FF, 15, 0.4, 0, 0);" text="🔥 VIDALBET SLOTS 🔥" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblSaldoSlots" style="-fx-text-fill: #E5C04A; -fx-font-size: 22px; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, #E5C04A, 15, 0.4, 0, 0);" text="Saldo: 0.00 €" />
    </HBox>

    <HBox alignment="CENTER" spacing="60.0" VBox.vgrow="ALWAYS" style="-fx-padding: 40;">

        <VBox alignment="CENTER" spacing="40.0" styleClass="machine-container">

            <HBox alignment="CENTER" spacing="20.0" styleClass="reels-container">
                <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot1" text="💎" styleClass="slot-text"/></VBox>
                <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot2" text="💎" styleClass="slot-text"/></VBox>
                <VBox alignment="CENTER" styleClass="slot-drum"><Label fx:id="slot3" text="💎" styleClass="slot-text"/></VBox>
            </HBox>

            <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #0E1116; -fx-padding: 20 40; -fx-background-radius: 15; -fx-border-color: #2D323E; -fx-border-radius: 15;">
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <Label text="APUESTA (€)" style="-fx-text-fill: #7A808C; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    <TextField fx:id="txtApuesta" text="5" styleClass="neon-textfield" prefWidth="130.0" />
                </VBox>
                <Button fx:id="btnPalanca" onAction="#tirarDeLaPalanca" styleClass="btn-spin-neon" text="TIRAR 🎰" />
            </HBox>

        </VBox>

        <VBox spacing="20.0" styleClass="paytable-container">
            <Label text="TABLA DE PREMIOS" styleClass="paytable-title" />
            <Region style="-fx-background-color: #00D4FF; -fx-pref-height: 2px; -fx-opacity: 0.7;" />

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="paytable-row-jackpot">
                <Label text="💎 💎 💎" styleClass="paytable-symbols" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT">
                    <Label text="JACKPOT" styleClass="paytable-prize-gold" />
                    <Label text="Premio Máximo" style="-fx-text-fill: #E5C04A; -fx-font-size: 12px; -fx-opacity: 0.8;" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="paytable-row">
                <Label text="🍒 🍒 🍒" styleClass="paytable-symbols" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Super Premio" styleClass="paytable-prize" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="paytable-row">
                <Label text="🍋 🍋 🍋" styleClass="paytable-symbols" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Premio Normal" styleClass="paytable-prize" />
            </HBox>
        </VBox>

    </HBox>
</VBox>