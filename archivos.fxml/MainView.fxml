<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #161920;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #161920; -fx-padding: 20 30 20 30;">
            <Label text="VIDALBET" style="-fx-text-fill: #E5C04A; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Arial';"/>

            <Region HBox.hgrow="ALWAYS" />

            <Label text="Joan Pere  |  Balance: 1.250,75 €" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="30" style="-fx-background-color: #1C2028; -fx-padding: 40 20 20 30; -fx-pref-width: 220;">
            <Label text="INICI" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="ESPORTS" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="CASINO" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="HISTORIAL" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="PERFIL" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="30" style="-fx-padding: 30;">

            <TableView prefHeight="200.0" style="-fx-background-color: #1C2028; -fx-border-color: #2D323E;">
                <columns>
                    <TableColumn text="ESDEVINIMENT" prefWidth="250.0" />
                    <TableColumn text="QUOTA X" prefWidth="100.0" />
                    <TableColumn text="QUOTA1" prefWidth="100.0" />
                    <TableColumn text="QUOTA2" prefWidth="100.0" />
                </columns>
                <placeholder>
                    <Label text="Tabla sin contenido" style="-fx-text-fill: #7A808C;"/>
                </placeholder>
            </TableView>

            <VBox spacing="20" style="-fx-border-color: #E5C04A; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 25; -fx-background-color: #1C2028;">

                <TextField promptText="IMPORTAR APOSTA" style="-fx-background-color: white; -fx-text-fill: black; -fx-max-width: 250; -fx-font-weight: bold; -fx-padding: 8;"/>

                <Label text="PREMI POTENCIAL" style="-fx-text-fill: #E5C04A; -fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Button text="CONFIRMAR APOSTA" style="-fx-background-color: #E5C04A; -fx-text-fill: black; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 4; -fx-cursor: hand;"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>