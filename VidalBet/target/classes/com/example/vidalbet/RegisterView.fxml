<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="650.0" prefWidth="800.0" spacing="10" style="-fx-background-color: #161920; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.RegisterController">

    <Label style="-fx-text-fill: #E5C04A; -fx-font-size: 28px; -fx-font-weight: bold;" text="VIDALBET" />
    <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 0 0 10 0;" text="CREAR COMPTE" />

    <VBox maxWidth="650.0" spacing="15.0" style="-fx-background-color: #1C2028; -fx-padding: 25; -fx-background-radius: 10; -fx-border-color: #2D323E; -fx-border-radius: 10;">

        <Label style="-fx-text-fill: #E5C04A; -fx-font-size: 14px; -fx-font-weight: bold;" text="Dades Personals" />

        <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" />
                <ColumnConstraints percentWidth="50.0" />
            </columnConstraints>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Nom" />
                <TextField fx:id="txtNom" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Cognoms" />
                <TextField fx:id="txtCognoms" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Data de naixement" />
                <DatePicker fx:id="dpNaixement" maxWidth="Infinity" style="-fx-background-color: #161920;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="País" />
                <TextField fx:id="txtPais" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Comunitat Autònoma" />
                <TextField fx:id="txtComunitat" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Codi Postal" />
                <TextField fx:id="txtCP" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <Separator opacity="0.2" />

        <Label style="-fx-text-fill: #E5C04A; -fx-font-size: 14px; -fx-font-weight: bold;" text="Mètode de Pagament" />

        <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" />
                <ColumnConstraints percentWidth="50.0" />
            </columnConstraints>

            <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Número de Targeta" />
                <TextField fx:id="txtTargeta" promptText="0000 0000 0000 0000" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Nom del Titular" />
                <TextField fx:id="txtTitular" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
            </VBox>

            <HBox spacing="15.0" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="Data Venciment (MM/AA)" />
                    <TextField fx:id="txtVenciment" promptText="MM/AA" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #7A808C; -fx-font-size: 11px;" text="CVV" />
                    <TextField fx:id="txtCVV" promptText="123" style="-fx-background-color: #161920; -fx-text-fill: white; -fx-border-color: #2D323E;" />
                </VBox>
            </HBox>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <VBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <Button maxWidth="Infinity" onAction="#handleRegistrar" style="-fx-background-color: #E5C04A; -fx-text-fill: black; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;" text="REGISTRAR-SE" />
            <Button maxWidth="Infinity" onAction="#handleTornarLogin" style="-fx-background-color: transparent; -fx-text-fill: #7A808C; -fx-cursor: hand;" text="Tornar a l'inici de sessió" />
        </VBox>
    </VBox>
</VBox>