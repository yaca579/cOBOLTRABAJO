<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="720.0" prefWidth="1280.0" spacing="30.0" style="-fx-background-color: #12151B;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.RetirarController">
    <children>
        <VBox alignment="CENTER" spacing="10.0">
            <Label style="-fx-text-fill: #E5C04A; -fx-font-size: 32px; -fx-font-weight: bold;" text="RETIRAR FONS" />
            <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="Indica la quantitat que vols transferir al teu banc" />
        </VBox>

        <VBox maxWidth="400.0" spacing="25.0" styleClass="dialog-pane" style="-fx-padding: 40; -fx-background-color: #1C2028; -fx-background-radius: 15;">
            <VBox spacing="8.0">
                <Label style="-fx-text-fill: #7A808C; -fx-font-size: 12px; -fx-font-weight: bold;" text="IMPORT A RETIRAR (€)" />
                <TextField fx:id="txtImportRetirar" promptText="0.00" styleClass="bet-input" style="-fx-font-size: 18px; -fx-text-fill: #E5C04A;" />
            </VBox>

            <VBox spacing="15.0">
                <Button maxWidth="Infinity" onAction="#handleRetirarDinero" styleClass="bet-confirm-button" text="CONFIRMAR RETIRADA" />
                <Button maxWidth="Infinity" onAction="#handleVolverInici" styleClass="sidebar-button" style="-fx-text-fill: #7A808C;" text="Cancel·lar" />
            </VBox>
        </VBox>

        <Label fx:id="lblSaldoDisponible" style="-fx-text-fill: #444a55; -fx-font-size: 14px;" text="Saldo disponible: 0,00 €" />
    </children>
</VBox>