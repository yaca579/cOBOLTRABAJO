<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #161920;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vidalbet.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 30;">
            <Label style="-fx-text-fill: #E5C04A; -fx-font-size: 24px; -fx-font-weight: bold;" text="VIDALBET" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblUserInfo" style="-fx-text-fill: white; -fx-font-size: 14px;" text="Joan Pere  |  Balance: 1.250,75 €" />
        </HBox>
    </top>

    <left>
        <VBox spacing="25" style="-fx-background-color: #1C2028; -fx-padding: 40 30; -fx-pref-width: 200;">
            <Button onAction="#navInici" style="-fx-background-color: transparent; -fx-text-fill: white;" text="INICI" />
            <Button onAction="#navEsports" style="-fx-background-color: transparent; -fx-text-fill: white;" text="ESPORTS" />
            <Button onAction="#navCasino" style="-fx-background-color: transparent; -fx-text-fill: white;" text="CASINO" />
            <Button onAction="#navHistorial" style="-fx-background-color: transparent; -fx-text-fill: white;" text="HISTORIAL" />
            <Button onAction="#navPerfil" style="-fx-background-color: transparent; -fx-text-fill: white;" text="PERFIL" />
        </VBox>
    </left>

    <center>
        <VBox spacing="25" style="-fx-padding: 20;">
            <TableView fx:id="tablaEventos" prefHeight="250.0" style="-fx-background-color: #1C2028;">
                <columns>
                    <TableColumn fx:id="colEsdeveniment" prefWidth="200.0" text="ESDEVENIMENT" />
                    <TableColumn fx:id="colQuotaX" prefWidth="80.0" text="QUOTA X" />
                    <TableColumn fx:id="colQuota1" prefWidth="80.0" text="QUOTA 1" />
                    <TableColumn fx:id="colQuota2" prefWidth="80.0" text="QUOTA 2" />
                </columns>
            </TableView>

            <VBox spacing="15" style="-fx-border-color: #E5C04A; -fx-border-radius: 10; -fx-padding: 20; -fx-background-color: #1C2028;">
                <TextField fx:id="txtImportAposta" promptText="IMPORT APOSTA" style="-fx-max-width: 200;" />
                <Label fx:id="lblPremiPotencial" style="-fx-text-fill: #E5C04A; -fx-font-weight: bold;" text="PREMI POTENCIAL" />
                <Button onAction="#handleConfirmarAposta" style="-fx-background-color: #E5C04A; -fx-text-fill: black; -fx-font-weight: bold;" text="CONFIRMAR APOSTA" />
            </VBox>
        </VBox>
    </center>

</BorderPane>